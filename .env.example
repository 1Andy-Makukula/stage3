# API (Node server on port 3001 by default)
PORT=3001
LOG_LEVEL=info
NODE_ENV=development

# Flutterwave — set in production; webhook rejects unsigned calls when NODE_ENV=production
FLW_SECRET_HASH=

# Optional: direct API URL for the SPA (defaults to same-origin /api via Vite proxy)
# VITE_API_URL=http://localhost:3001
